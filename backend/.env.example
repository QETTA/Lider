# ============================================
# LIDER Backend Environment Configuration
# ============================================

# Server
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/lider?schema=public"
# Vector extension for pgvector (Phase 3)
# DATABASE_URL="postgresql://user:password@localhost:5432/lider?schema=public&connection_limit=1&pool_timeout=20"

# JWT
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# AI Providers
# ============================================

# Kimi AI (Moonshot)
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_API_KEY=your-kimi-api-key

# Anthropic (Claude)
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embedding for Vector Search (Phase 3)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=your-openai-api-key

# ============================================
# Vector Database (Phase 3)
# ============================================

# Options: 'pgvector' | 'pinecone' | 'weaviate'
VECTOR_DB_PROVIDER=pgvector
ENABLE_RERANK=true

# Pinecone (if using)
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX_NAME=lider-docs
PINECONE_ENVIRONMENT=us-west1-gcp

# Weaviate (if using)
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-key

# ============================================
# Notification Services (Phase 2)
# ============================================

# Firebase Cloud Messaging (Push)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_PATH=/path/to/firebase-service-account.json
# Or inline JSON (base64 encoded)
FIREBASE_PRIVATE_KEY_BASE64=base64-encoded-json

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM=noreply@lider.ai
EMAIL_FROM_NAME=LIDER 알림

# AWS SES (Alternative Email)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx
SES_FROM_EMAIL=noreply@lider.ai

# Twilio (SMS - Global)
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=+8210xxxx

# Naver Cloud Platform (SMS - Korea)
NAVER_CLOUD_ACCESS_KEY=xxx
NAVER_CLOUD_SECRET_KEY=xxx
NAVER_CLOUD_SMS_SERVICE_ID=ncp:sms:kr:xxx
NAVER_CLOUD_SMS_SENDER=01012345678

# ============================================
# File Storage (AWS S3)
# ============================================

AWS_S3_BUCKET=lider-documents
AWS_S3_REGION=ap-northeast-2
AWS_S3_ACCESS_KEY=xxx
AWS_S3_SECRET_KEY=xxx

# ============================================
# Redis (Caching & Queue)
# ============================================

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================
# Cron & Scheduling
# ============================================

# Visit reminder check interval (in minutes)
VISIT_REMINDER_INTERVAL=1
# Overdue check interval (in minutes)
VISIT_OVERDUE_INTERVAL=5

# ============================================
# Feature Flags
# ============================================

ENABLE_VECTOR_SEARCH=false
ENABLE_REALTIME_NOTIFICATIONS=false
ENABLE_AUDIT_LOG=true

# ============================================
# Monitoring & Logging
# ============================================

# Sentry (Error Tracking)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Datadog / New Relic (APM)
APM_PROVIDER=none
DATADOG_API_KEY=xxx

# ============================================
# Testing
# ============================================

# Test database
TEST_DATABASE_URL="postgresql://user:password@localhost:5432/lider_test"

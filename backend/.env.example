# Core runtime database
DATABASE_URL="postgresql://yoyang:yoyang123@localhost:5432/yoyang_radar?schema=public"

# Core runtime auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173"

# Public data status
PUBLIC_DATA_API_KEY="your-public-data-api-key"
PUBLIC_DATA_BASE_URL="https://apis.data.go.kr"

# Kimi AI API (document extraction / draft assistance)
KIMI_API_KEY="your-kimi-api-key"
KIMI_BASE_URL="https://api.moonshot.cn/v1"

# Anthropic API (assistant / core AI helper responses)
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_BASE_URL="https://api.anthropic.com/v1"
ANTHROPIC_MODEL="claude-sonnet-4-6"

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR="./uploads"

# Logging
LOG_LEVEL=info

# Note:
# CORE_API_BASE_URL is a Worker-side setting, not a backend env var.
# AI_PROXY_* values are optional fallback settings and should be documented in
# the Worker/Railway runbook, not treated as backend core runtime requirements.

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum VisitStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

enum VisitType {
  REGULAR
  FIRST
  EMERGENCY
  FOLLOW_UP
  EVALUATION
}

enum NotificationType {
  VISIT_REMINDER
  VISIT_OVERDUE
  VISIT_COMPLETED
  SCHEDULE_CHANGED
  NEW_DOCUMENT
  CONSULTATION_DUE
  EMERGENCY_ALERT
  SYSTEM_NOTICE
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum UserRole {
  ADMIN
  MANAGER
  WORKER
  VIEWER
}

enum CareGrade {
  GRADE_1
  GRADE_2
  GRADE_3
  GRADE_4
  GRADE_5
  GRADE_6
  PENDING
}

// ============================================
// Core Models
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String // hashed
  name          String
  phone         String?
  role          UserRole  @default(WORKER)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  visitSchedules  VisitSchedule[]
  notifications   Notification[]
  careRecords     CareRecord[]
  
  @@index([email])
  @@index([role])
  @@map("users")
}

model Recipient {
  id              String    @id @default(uuid())
  name            String
  phone           String?
  address         String?
  detailAddress   String?
  birthDate       DateTime?
  careGrade       CareGrade @default(PENDING)
  longTermCareId  String?   @unique // 요양인정번호
  emergencyContact String?
  emergencyPhone  String?
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  visitSchedules  VisitSchedule[]
  careRecords     CareRecord[]
  documents       Document[]
  
  @@index([name])
  @@index([longTermCareId])
  @@index([careGrade])
  @@map("recipients")
}

// ============================================
// VisitSchedule Model (신규)
// ============================================

model VisitSchedule {
  id                String      @id @default(uuid())
  recipientId       String
  workerId          String
  
  // Scheduling
  scheduledDate     DateTime
  scheduledTime     DateTime?
  estimatedDuration Int         @default(60) // minutes
  
  // Status & Type
  status            VisitStatus @default(SCHEDULED)
  visitType         VisitType   @default(REGULAR)
  
  // Details
  notes             String?     @db.Text
  visitPurpose      String? // 방문 목적
  requiredSkills    String[]    @default([]) // 필요 전문성
  
  // Actual visit times
  actualStartTime   DateTime?
  actualEndTime     DateTime?
  
  // Cancellation
  cancelledAt       DateTime?
  cancelledBy       String?
  cancellationReason String?
  
  // Location tracking (mobile)
  startLatitude     Float?
  startLongitude    Float?
  endLatitude       Float?
  endLongitude      Float?
  
  // Metadata
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  createdBy         String?
  
  // Relations
  recipient         Recipient   @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  worker            User        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  notifications     Notification[]
  careRecord        CareRecord? // 1:1 관계 - 방문 완료 후 생성
  
  @@index([recipientId])
  @@index([workerId])
  @@index([scheduledDate])
  @@index([status])
  @@index([scheduledDate, status])
  @@index([workerId, scheduledDate])
  @@map("visit_schedules")
}

// ============================================
// Notification Model (신규)
// ============================================

model Notification {
  id                String               @id @default(uuid())
  userId            String
  
  // Content
  type              NotificationType
  title             String
  message           String              @db.Text
  priority          NotificationPriority @default(NORMAL)
  
  // Status
  isRead            Boolean             @default(false)
  readAt            DateTime?
  
  // Multi-channel delivery status
  channels          Json                @default("{}") // { push: "sent", email: "sent", sms: "skipped" }
  
  // Related entity (polymorphic reference)
  relatedEntityType String? // "VisitSchedule", "CareRecord", etc.
  relatedEntityId   String?
  
  // Scheduling
  scheduledFor      DateTime? // 예약 발송 시간
  sentAt            DateTime? // 실제 발송 시간
  
  // Retry tracking
  retryCount        Int                 @default(0)
  lastError         String?
  
  // Metadata
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitSchedule     VisitSchedule?      @relation(fields: [relatedEntityId], references: [id], map: "notification_visit_schedule_fk")
  
  @@index([userId])
  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@index([scheduledFor])
  @@index([relatedEntityType, relatedEntityId])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================
// CareRecord Model (기존)
// ============================================

model CareRecord {
  id              String    @id @default(uuid())
  recipientId     String
  workerId        String
  visitScheduleId String?   @unique // 완료된 방문 일정과 연결
  
  recordDate      DateTime  @default(now())
  condition       String?   @db.Text // 건강 상태
  activities      String[]  @default([]) // 수행 활동
  specialNotes    String?   @db.Text // 특이사항
  mood            String? // 기분 상태
  mealStatus      String? // 식사 상태
  medicationStatus String? // 복약 상태
  
  // Photos
  photos          String[]  @default([]) // S3 URLs
  
  // Location
  latitude        Float?
  longitude       Float?
  locationAccuracy Float?
  
  // Signatures
  workerSignature String? // Base64 encoded
  familySignature String?
  
  // AI generated
  aiSummary       String?   @db.Text
  aiTags          String[]  @default([])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  recipient       Recipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  worker          User      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  visitSchedule   VisitSchedule? @relation(fields: [visitScheduleId], references: [id])
  
  @@index([recipientId])
  @@index([workerId])
  @@index([recordDate])
  @@index([recipientId, recordDate])
  @@map("care_records")
}

// ============================================
// Document Model (기존)
// ============================================

model Document {
  id              String    @id @default(uuid())
  recipientId     String
  
  // Document info
  fileName        String
  fileUrl         String    // S3 URL
  fileType        String    // mime type
  fileSize        Int       // bytes
  
  // Classification
  documentType    String?   // EVAL_FORM, DOCTOR_NOTE, DIAGNOSIS, etc.
  extractedData   Json?     // AI 추출 데이터
  
  // Processing
  isProcessed     Boolean   @default(false)
  processedAt     DateTime?
  errorMessage    String?
  
  // Vector embedding for search (Phase 3)
  embeddingId     String?   // Reference to vector DB
  
  uploadedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  recipient       Recipient @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  
  @@index([recipientId])
  @@index([documentType])
  @@index([isProcessed])
  @@index([createdAt])
  @@map("documents")
}

// ============================================
// Vector Embeddings for Search (Phase 3)
// ============================================

model DocumentEmbedding {
  id            String    @id @default(uuid())
  documentId    String    @unique
  content       String    @db.Text // Chunked content
  embedding     Unsupported("vector(1536)") // pgvector extension required
  metadata      Json      @default("{}") // chunk info, page num, etc.
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([documentId])
  // Note: vector index created via raw SQL migration
  @@map("document_embeddings")
}

// ============================================
// System/Config Models
// ============================================

model NotificationPreference {
  id            String    @id @default(uuid())
  userId        String    @unique
  
  // Channel preferences
  enablePush    Boolean   @default(true)
  enableEmail   Boolean   @default(true)
  enableSMS     Boolean   @default(false)
  
  // Type preferences
  visitReminderMinutes Int @default(30)
  notifyVisitOverdue   Boolean @default(true)
  notifyNewDocument    Boolean @default(true)
  notifySystemNotice   Boolean @default(true)
  
  // Quiet hours
  quietHoursStart      String? // "22:00"
  quietHoursEnd        String? // "08:00"
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@map("notification_preferences")
}

model ApiKey {
  id          String    @id @default(uuid())
  name        String    // e.g., "Kimi AI", "SendGrid"
  key         String    // encrypted
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("api_keys")
}

// ============================================
// Audit Logs
// ============================================

model AuditLog {
  id          String    @id @default(uuid())
  userId      String?
  action      String    // CREATE_VISIT, UPDATE_RECORD, etc.
  entityType  String    // VisitSchedule, CareRecord, etc.
  entityId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime  @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

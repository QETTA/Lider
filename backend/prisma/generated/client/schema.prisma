// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Enums
// ============================================

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

enum PlanTier {
  STARTER
  GROWTH
  ENTERPRISE
}

enum SessionStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum EndpointType {
  ASSIST
  EXTRACT
  ACTION_PREVIEW
}

enum ExtractionDocType {
  POSTER
  INVOICE
  FORM
  SCREEN
  GENERIC
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  NOT_NEEDED
}

enum ActionType {
  TICKET_CLOSE
  REFUND_PROCESS
  DATA_EXPORT
  USER_DELETE
  ORG_DELETE
  CONFIG_CHANGE
  BULK_OPERATION
}

enum ConfirmationMethod {
  SSO
  MFA
  EMAIL
  MANUAL
}

enum BadcaseCategory {
  JSON_INVALID
  HALLUCINATION
  WRONG_TOOL
  EXTRACTION_FAIL
  SCHEMA_MISMATCH
  TIMEOUT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FixStatus {
  OPEN
  IN_PROGRESS
  FIXED
  WONT_FIX
}

enum DocumentPurpose {
  EXTRACT
  REFERENCE
  ATTACHMENT
}

enum FundingProgramStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

enum ApplicationStatus {
  PREPARING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  COMPLETED
}

// ============================================
// Core Models
// ============================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  plan      PlanTier @default(STARTER)
  settings  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  documents           Document[]
  fundingApplications FundingApplication[]

  @@index([plan])
  @@map("organizations")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         UserRole  @default(VIEWER)
  orgId        String
  preferences  Json      @default("{}")
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLoginAt  DateTime?

  // Relations
  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sessions         Session[]
  requestLogs      RequestLog[]
  actionExecutions ActionExecution[]

  @@index([email])
  @@index([orgId])
  @@index([role])
  @@map("users")
}

model Session {
  id            String        @id @default(uuid())
  userId        String
  orgId         String
  status        SessionStatus @default(ACTIVE)
  contextTokens Int           @default(0)
  metadata      Json          @default("{}")
  createdAt     DateTime      @default(now())
  expiresAt     DateTime

  // Relations
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestLogs RequestLog[]

  @@index([userId])
  @@index([orgId])
  @@index([status])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================
// AI Operation Models
// ============================================

model RequestLog {
  id               String       @id @default(uuid())
  requestId        String       @unique
  sessionId        String?
  userId           String?
  orgId            String?
  endpoint         EndpointType
  modelUsed        String
  promptTokens     Int
  completionTokens Int
  latencyMs        Int
  fallbackUsed     Boolean      @default(false)
  schemaValid      Boolean      @default(true)
  toolCount        Int          @default(0)
  estimatedCostUsd Decimal      @db.Decimal(10, 6)
  traceId          String?
  createdAt        DateTime     @default(now())

  // Relations
  session        Session?        @relation(fields: [sessionId], references: [id])
  user           User?           @relation(fields: [userId], references: [id])
  extractions    Extraction[]
  actionPreviews ActionPreview[]
  badcases       Badcase[]

  @@index([userId, createdAt])
  @@index([sessionId])
  @@index([traceId])
  @@index([orgId, createdAt])
  @@index([endpoint, createdAt])
  @@map("request_logs")
}

model Extraction {
  id               String            @id @default(uuid())
  requestId        String
  fileId           String?
  docType          ExtractionDocType @default(GENERIC)
  fields           Json
  confidenceScores Json
  warnings         Json              @default("[]")
  needsReview      Boolean           @default(false)
  reviewStatus     ReviewStatus      @default(NOT_NEEDED)
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())

  // Relations
  requestLog RequestLog @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([needsReview, createdAt])
  @@index([docType])
  @@index([reviewStatus])
  @@map("extractions")
}

model ActionPreview {
  id                        String     @id @default(uuid())
  requestId                 String
  actionType                ActionType
  targetType                String
  targetId                  String?
  payload                   Json
  allowed                   Boolean
  missingChecks             Json       @default("[]")
  impactSummary             Json
  humanConfirmationRequired Boolean    @default(false)
  previewToken              String?    @unique
  expiresAt                 DateTime?
  createdAt                 DateTime   @default(now())

  // Relations
  requestLog RequestLog        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  executions ActionExecution[]

  @@index([previewToken])
  @@index([actionType])
  @@index([allowed])
  @@map("action_previews")
}

model ActionExecution {
  id                 String             @id @default(uuid())
  previewId          String
  executedBy         String
  executedAt         DateTime           @default(now())
  confirmationMethod ConfirmationMethod
  result             Json
  auditTrail         Json               @default("{}")

  // Relations
  preview ActionPreview @relation(fields: [previewId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [executedBy], references: [id])

  @@index([previewId])
  @@index([executedBy])
  @@index([executedAt])
  @@map("action_executions")
}

// ============================================
// Quality & Ops Models
// ============================================

model Badcase {
  id                String          @id @default(uuid())
  requestId         String
  category          BadcaseCategory
  severity          Severity
  description       String          @db.Text
  inputSnapshot     Json
  expectedOutput    Json?
  actualOutput      Json?
  rootCauseAnalysis String?         @db.Text
  fixStatus         FixStatus       @default(OPEN)
  fixedBy           String?
  fixedAt           DateTime?
  createdAt         DateTime        @default(now())
  resolvedAt        DateTime?

  // Relations
  requestLog RequestLog @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([category, severity])
  @@index([fixStatus, createdAt])
  @@index([severity])
  @@index([createdAt])
  @@map("badcases")
}

// ============================================
// Document & Search Models
// ============================================

model Document {
  id            String          @id @default(uuid())
  orgId         String
  fileName      String
  mimeType      String
  sizeBytes     Int
  uploadedBy    String?
  purpose       DocumentPurpose @default(ATTACHMENT)
  storagePath   String
  extractedText String?         @db.Text
  createdAt     DateTime        @default(now())
  expiresAt     DateTime?

  // Relations
  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  embeddings DocumentEmbedding[]

  @@index([orgId])
  @@index([purpose])
  @@index([createdAt])
  @@index([expiresAt])
  @@map("documents")
}

model DocumentEmbedding {
  id         String                      @id @default(uuid())
  documentId String
  content    String                      @db.Text
  embedding  Unsupported("vector(1536)")
  metadata   Json                        @default("{}")
  createdAt  DateTime                    @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_embeddings")
}

// ============================================
// Government Funding Models (LIDER domain-specific)
// ============================================

model FundingProgram {
  id                 String               @id @default(uuid())
  programName        String
  agency             String
  maxAmount          Int?
  minAmount          Int?
  targetIndustries   String[]             @default([])
  targetCompanySizes String[]             @default([])
  applicationStart   DateTime?
  applicationEnd     DateTime?
  eligibility        Json                 @default("{}")
  description        String?              @db.Text
  sourceUrl          String?
  status             FundingProgramStatus @default(ACTIVE)
  lastScrapedAt      DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Relations
  applications FundingApplication[]

  @@index([agency])
  @@index([applicationEnd])
  @@index([status])
  @@index([programName])
  @@map("funding_programs")
}

model FundingApplication {
  id          String            @id @default(uuid())
  orgId       String
  programId   String
  status      ApplicationStatus @default(PREPARING)
  submittedAt DateTime?
  documents   Json              @default("[]")
  notes       String?           @db.Text
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  program FundingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([programId])
  @@index([status])
  @@index([createdAt])
  @@map("funding_applications")
}

// ============================================
// Audit & Config Models
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  orgId      String?
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  key        String // encrypted
  orgId      String?
  isActive   Boolean   @default(true)
  expiresAt  DateTime?
  lastUsedAt DateTime?
  scopes     String[]  @default([])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([orgId])
  @@index([isActive])
  @@map("api_keys")
}

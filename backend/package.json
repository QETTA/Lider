{
  "name": "lider-backend",
  "version": "2.0.0",
  "description": "LIDER AI 업무 오케스트레이션 플랫폼 - 백엔드 API 서버",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",

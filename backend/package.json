    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/swagger": "^8.15.0",
    "@fastify/swagger-ui": "^4.2.0",
    "@prisma/client": "^5.20.0",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.5.0",
    "fastify": "^4.28.1",
    "form-data": "^4.0.1",
    "mammoth": "^1.12.0",
    "mime-types": "^2.1.35",
    "pdf-parse": "^2.4.5",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",

# Local development: call the backend directly.
VITE_API_BASE_URL=http://localhost:3001
VITE_DEMO_SYSTEM_STATUS=false

# Production same-origin: keep VITE_API_BASE_URL empty and let the Worker proxy
# core auth/onboarding/health/public-data requests to the backend.
# Primary Worker env:
# CORE_API_BASE_URL=https://your-core-api.example.com
# CORE_API_SHARED_SECRET=optional-shared-secret
#
# Optional public AI fallback env lives separately and is not part of the core
# runtime path:
# AI_PROXY_BASE_URL=https://your-ai-proxy.example.com
# AI_PROXY_SHARED_SECRET=optional-ai-proxy-shared-secret

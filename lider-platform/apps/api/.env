# LIDER AI Platform - Development Environment Configuration
# SQLite Mode (No Docker Required)

# Basic Settings
APP_NAME=LIDER AI Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Server Settings
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database - SQLite for Development
DATABASE_URL=sqlite+aiosqlite:///./lider_dev.db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis - Disabled for Development (Using memory cache fallback)
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# API Keys (Add your keys here)
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Security Settings
SECRET_KEY=dev-secret-key-change-in-production-2026
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS
CORS_ORIGINS=["*"]

# Model Routing Settings
DEFAULT_MODEL=kimi-k2-0905
FALLBACK_MODEL=claude-sonnet-4-6
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Cache TTL (seconds)
CACHE_TTL_SESSION=7200
CACHE_TTL_PERMISSIONS=900
CACHE_TTL_TOOL_RESULT=300
CACHE_TTL_MODEL_RESPONSE=3600

# Quality Thresholds
JSON_VALID_RATE_THRESHOLD=0.98
FALLBACK_RATE_THRESHOLD=0.20
GROUNDED_ANSWER_THRESHOLD=0.95

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/lider-uploads

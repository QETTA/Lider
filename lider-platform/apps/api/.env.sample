# LIDER API Environment Configuration
# Copy this file to .env and update the values

# Application Settings
APP_NAME=LIDER AI Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lider
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# AI Provider API Keys
# Get your API keys from:
# - Moonshot: https://platform.moonshot.cn/
# - Anthropic: https://console.anthropic.com/
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Security Settings
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# CORS Settings
CORS_ORIGINS=["*"]

# Model Routing
DEFAULT_MODEL=kimi-k2-0905
FALLBACK_MODEL=claude-sonnet-4-6
MAX_RETRIES=3
TIMEOUT_SECONDS=30

# Cache TTL Settings (seconds)
CACHE_TTL_SESSION=7200
CACHE_TTL_PERMISSIONS=900
CACHE_TTL_TOOL_RESULT=300
CACHE_TTL_MODEL_RESPONSE=3600

# Quality Thresholds
JSON_VALID_RATE_THRESHOLD=0.98
FALLBACK_RATE_THRESHOLD=0.20
GROUNDED_ANSWER_THRESHOLD=0.95

# File Upload Settings
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/tmp/lider-uploads

# Monitoring (Optional)
SENTRY_DSN=
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_STREAMING=true
ENABLE_ACTION_EXECUTION=true